# --- Transport ---
# Choose default transport when no CLI arg is given. Values: stdio | http
GWS_MCP_TRANSPORT=stdio

# --- HTTP transport (only used when transport=http) ---
GWS_MCP_HTTP_HOST=127.0.0.1
GWS_MCP_HTTP_PORT=8765
# Path the MCP endpoint listens on
GWS_MCP_HTTP_PATH=/mcp

# Bearer token required by clients in `Authorization: Bearer <token>`
# Generate one with: openssl rand -hex 32
# REQUIRED for http mode unless GWS_MCP_HTTP_INSECURE=1
GWS_MCP_AUTH_TOKEN=

# Disable bearer auth (DANGEROUS — only on a trusted local socket)
# GWS_MCP_HTTP_INSECURE=1

# CORS: comma-separated origins, or * (default: empty = no CORS headers)
GWS_MCP_HTTP_CORS_ORIGINS=

# --- gws CLI ---
# Absolute path to the gws binary (auto-resolved via PATH if empty)
GWS_MCP_GWS_BIN=

# Per-call timeout in milliseconds
GWS_MCP_CALL_TIMEOUT_MS=60000

# Max bytes of stdout to keep from a gws call (bigger output is truncated)
GWS_MCP_MAX_OUTPUT_BYTES=1048576

# --- Safety ---
# Comma-separated whitelist of allowed services. Empty = all services allowed.
# Example: drive,sheets,docs,calendar,gmail
GWS_MCP_ALLOWED_SERVICES=

# Comma-separated denylist (applied after whitelist)
# Example deny destructive: gmail.users.messages.send,drive.files.delete
GWS_MCP_DENIED_METHODS=

# Audit log file (NDJSON). Empty = stderr only.
GWS_MCP_AUDIT_LOG=

# --- Skills layer ---
# Directory to scan for skill guides. Default: ~/.agents/skills
GWS_MCP_SKILLS_DIR=
# Prefix that selects which subdirs are mounted (default: gws-)
GWS_MCP_SKILLS_PREFIX=gws-
# Set to "1" to disable the skills layer entirely
# GWS_MCP_SKILLS_DISABLED=1
