# ============================================================================
# YODY OmniChat — biến môi trường mẫu
# Sao chép thành .env.local và điền giá trị thật. KHÔNG commit secret.
# ============================================================================

# --- AI Gateway của YODY (BẮT BUỘC cho production) -------------------------
# Mọi lời gọi LLM PHẢI đi qua AI Gateway của YODY (không gọi thẳng provider).
# Endpoint tương thích OpenAI Chat Completions.
YODY_AI_GATEWAY_URL=
YODY_AI_GATEWAY_KEY=
YODY_AI_MODEL=yody-cs-agent

# --- Xác thực webhook ------------------------------------------------------
# Token verify dùng khi đăng ký webhook (Meta: hub.verify_token).
WEBHOOK_VERIFY_TOKEN=

# --- Facebook Messenger & Instagram (Meta Graph API) -----------------------
# Lấy từ Meta for Developers. App Secret dùng để verify X-Hub-Signature-256.
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=

# --- Zalo OA (Official Account) --------------------------------------------
ZALO_OA_ID=
ZALO_OA_SECRET_KEY=
ZALO_OA_ACCESS_TOKEN=

# --- Zalo PA (Personal Account) --------------------------------------------
ZALO_PA_ACCESS_TOKEN=
