{
  "name": "gws-mcp",
  "version": "0.3.0",
  "description": "MCP server wrapping the local `gws` (Google Workspace) CLI, so sandboxed agents (Claude Cowork, etc.) can use Google Workspace through your host-side OAuth credentials.",
  "type": "module",
  "bin": {
    "gws-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "skills",
    "README.md",
    "README.vi.md",
    "LICENSE",
    "CHANGELOG.md",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/index.ts http",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js http",
    "typecheck": "tsc --noEmit",
    "test:unit": "node test/unit-encode.mjs",
    "test:integration": "node test/integration-batchupdate.mjs && node test/integration-regression.mjs",
    "test:smoke": "node test/smoke-skills.mjs",
    "test": "npm run test:unit && npm run test:integration && npm run test:smoke",
    "clean": "rm -rf dist",
    "prepack": "npm run build"
  },
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "google-workspace",
    "gws",
    "claude",
    "claude-desktop",
    "claude-cowork",
    "anthropic",
    "google-drive",
    "google-sheets",
    "gmail",
    "google-calendar"
  ],
  "author": "fioenix",
  "license": "MIT",
  "homepage": "https://github.com/fioenix/gws-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fioenix/gws-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/fioenix/gws-mcp/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
